msgstr "Field %(field)s must be a JSON array"

#: views.py
#, python-format
msgid "字段 %(field)s 须为 off、allow_only_in_pool 或 block_in_pool"
msgstr "Field %(field)s must be off, allow_only_in_pool, or block_in_pool"

